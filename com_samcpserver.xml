<?xml version="1.0" encoding="utf-8"?>
<extension type="component" version="3.1" method="upgrade">
    <name>COM_SAMCPSERVER</name>
    <author>Alejo Sotelo</author>
    <authorEmail>soporte@alejosotelo.com.ar</authorEmail>
    <authorUrl>https://alejosotelo.com.ar</authorUrl>
    <creationDate>2026</creationDate>
    <copyright>Copyright (C) 2026 Alejo Sotelo. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later</license>
    <version>1.4.0</version>
    <description>COM_SAMCPSERVER_DESC</description>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>

    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>

    <update>
        <schemas>
            <schemapath type="mysql">sql/updates/mysql</schemapath>
        </schemas>
    </update>

    <files folder="site">
        <folder>helpers</folder>
        <file>samcpserver.php</file>
        <file>controller.php</file>
        <file>router.php</file>
    </files>

    <administration>
        <menu link="option=com_samcpserver">SA MCP Server</menu>
        <files folder="admin">
            <folder>controllers</folder>
            <folder>models</folder>
            <folder>tables</folder>
            <folder>views</folder>
            <folder>sql</folder>
            <folder>language</folder>
            <file>samcpserver.php</file>
            <file>controller.php</file>
        </files>
    </administration>
</extension>